# EB 打包排除规则（存在此文件时 EB 不读 .gitignore，改读这里）
# frontend/dist/ 故意不排除 —— EB 需要它来托管前端

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Node / Vite（源码和缓存不需要，dist/ 保留）
node_modules/
frontend/.vite/
.vite/

# Environment files
.env
.env.local
.env.*.local

# Data pipeline intermediates
data/newData/

# Personal narrative drafts
Phase1/

# Internal design docs
CLAUDE.md
ProjectPlan.md
SIMULATION.md
SIMULATION_IMPLEMENTATION_PLAN.md
simulation.text

